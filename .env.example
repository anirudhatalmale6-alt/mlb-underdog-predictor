# The Odds API key (get from https://the-odds-api.com)
ODDS_API_KEY=your_key_here

# Output preferences
OUTPUT_FORMAT=csv
# Options: csv, json, both

# Edge threshold - minimum implied edge to recommend a pick (e.g., 0.05 = 5%)
EDGE_THRESHOLD=0.03

# Odds range for qualifying underdogs (American format)
MIN_UNDERDOG_ODDS=130
MAX_UNDERDOG_ODDS=250

# Model retraining - set to "true" to retrain daily (slower), "false" to use saved model
RETRAIN_DAILY=false

# Logging level
LOG_LEVEL=INFO
